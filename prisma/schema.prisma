// Followr — Prisma Schema
// Run: npx prisma db push  (creates local SQLite DB)
// Run: npx prisma studio   (visual DB browser)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── NextAuth tables ──────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  settings      Settings?
  threads       Thread[]
  templates     Template[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Followr tables ───────────────────────────────────────────

model Settings {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // The CC address Followr watches (e.g. followup@acme.com)
  watchedCcAddress String  @default("")
  // Global default send mode: "auto" | "approval"
  defaultSendMode  String  @default("auto")
  // Push notifications enabled
  notificationsEnabled Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// A thread = one email chain Followr is tracking
model Thread {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email metadata
  subject        String
  recipientName  String
  recipientEmail String
  gmailThreadId  String   // Gmail thread ID for sending replies
  gmailMessageId String   // The original message ID

  // Send mode for this specific thread
  // "auto"     = fires automatically on schedule
  // "approval" = waits for user approval before sending
  sendMode       String   @default("auto")

  // Thread status:
  // "pending"   = detected, not yet configured
  // "active"    = sequence running
  // "overdue"   = manual approval missed
  // "replied"   = recipient replied, sequence paused
  // "completed" = all steps sent, no reply
  // "snoozed"   = user deferred
  status         String   @default("pending")

  // When snoozed, resume at this date
  snoozedUntil   DateTime?

  steps          Step[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// A step = one follow-up in the sequence
model Step {
  id           String   @id @default(cuid())
  threadId     String
  thread       Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  stepNumber   Int      // 1, 2, 3...

  // Timing: send X days after the previous step (or thread creation for step 1)
  sendAfterDays Int

  // Message source: "template" | "custom"
  messageSource String   @default("template")
  templateId    String?  // FK to Template (if messageSource = "template")
  template      Template? @relation(fields: [templateId], references: [id])
  customBody    String?  // Used when messageSource = "custom"

  // Step status:
  // "pending"  = not yet due
  // "due"      = due today (auto) or awaiting approval (manual)
  // "overdue"  = approval deadline missed (manual threads only)
  // "sent"     = successfully sent
  // "skipped"  = user skipped this step
  status        String   @default("pending")

  scheduledAt   DateTime // When this step should fire
  sentAt        DateTime? // When it was actually sent

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([threadId, stepNumber])
}

// Reusable message templates
model Template {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  // Body supports variables: {{name}}, {{subject}}, {{invoice}}, {{sender}}
  body        String

  steps       Step[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
